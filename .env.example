# ──────────────────────────────────────────────────────────
# apt-planner 환경 변수 (운영 시 .env.local 또는 Vercel/Hosting 콘솔에 설정)
# ──────────────────────────────────────────────────────────

# (필수) 사이트 URL — PDF에 삽입되는 공유 QR이 가리키는 주소
# 도메인을 연결한 뒤 실제 도메인으로 교체
NEXT_PUBLIC_SITE_URL=https://apt-planner.kr

# (선택) Google Analytics 4 측정 ID — 같은 ID로 여러 서브도메인 통합 추적 가능
# 형식: G-XXXXXXXXXX (GA Admin → 데이터 스트림에서 확인)
NEXT_PUBLIC_GA_ID=

# (선택) 입금 계좌 정보 — 스펙북·컨설팅 신청 모달에 노출. 비어 있으면 '—' placeholder.
NEXT_PUBLIC_PAYMENT_BANK=
NEXT_PUBLIC_PAYMENT_NUMBER=
NEXT_PUBLIC_PAYMENT_HOLDER=

# (선택) 스펙북 신청 알림
SPEC_WEBHOOK_URL=
SPEC_NOTIFY_TO=

# (선택 1) 컨설팅 신청을 외부 Webhook으로 전달 — Slack/Discord/Zapier 등
# 예: https://hooks.slack.com/services/T000/B000/XXXX
CONSULT_WEBHOOK_URL=

# (선택 2) Resend로 이메일 발송 — 신청 시 운영자에게 메일 알림
# Resend 가입 후 API 키와 발송할 메일 도메인 인증 필요
RESEND_API_KEY=
CONSULT_NOTIFY_TO=admin@example.com
CONSULT_NOTIFY_FROM=apt-planner <noreply@aptplanner.kr>

# ──────────────────────────────────────────────────────────
# 운영 도구 (scripts/) — npm run materials:sync 시에만 사용
# ──────────────────────────────────────────────────────────

# (선택) 자재마스터 엑셀 절대 경로
# 미설정 시 data/source/materials_master.xlsx (in-repo) 사용.
# 외부 클라우드 폴더(OneDrive/Dropbox) 또는 별도 보관 위치를 truth로 쓸 때 지정.
# 백슬래시는 이스케이프(\\) 또는 따옴표로 감싸기.
# 예: APT_MATERIALS_XLSX="C:\Users\user\Documents\Claude\Projects\int biz\materials_master.xlsx"
APT_MATERIALS_XLSX=

# (선택) 웹 관리자 페이지(/admin/materials) 비밀번호
# 설정 시 그 비밀번호를 알아야 자재마스터를 웹에서 편집 가능.
# 미설정 시 모든 관리자 API 요청이 401 거부 (가장 안전한 기본값).
# Vercel Settings → Environment Variables 에도 같은 값 설정 필요.
ADMIN_PASSWORD=
